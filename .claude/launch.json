{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static File Server (index.html)",
      "runtimeExecutable": "powershell",
      "runtimeArgs": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "serve.ps1"],
      "port": 8080
    },
    {
      "name": "Static File Server (npx serve)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-p", "3000", "."],
      "port": 3000
    }
  ]
}
